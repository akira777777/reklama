# Скопируйте этот файл в .env и заполните своими значениями.
# Получить API_ID и API_HASH: https://my.telegram.org -> API development tools.

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=00000000000000000000000000000000
SESSION_NAME=reklama

# --- Параметры рассылки (необязательно; есть дефолты в config.py) ---
# MESSAGE_FILE=message.txt
# FORCE_DOCUMENT=false
# DELAY_MIN_SEC=30
# DELAY_MAX_SEC=90
# BATCH_SIZE=50
# BATCH_PAUSE_MIN_SEC=300
# BATCH_PAUSE_MAX_SEC=900
# ACTIVE_HOURS=09:00-21:00

# ВНИМАНИЕ: файл .session (= доступ к вашему аккаунту) и .env — это секреты.
# Никогда не коммитьте их и не передавайте третьим лицам.
